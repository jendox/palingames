# Local development. Copy to .env and fill secrets.
# Production / staging on VPS: see deploy/env.example (Docker service hostnames).

# --- Django ---
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-generate-with-secrets-token-urlsafe
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Optional for tunneling / mobile testing: add * (dev only)
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,*
# Production / staging: comma-separated origins with scheme, e.g. https://dev.palingames.by
# DJANGO_CSRF_TRUSTED_ORIGINS=https://dev.palingames.by
# DJANGO_USE_WHITENOISE=true
# TAILWIND_CLI_USE_MINIFY=true
DJANGO_LOG_LEVEL=INFO
# Session lifetime when "remember me" is checked (default in settings: 1209600 = 14 days)
SESSION_COOKIE_AGE=1209600

# --- Email (SMTP) ---
# Local without SMTP: leave EMAIL_HOST unset → Django uses localhost:25 (or smtp4dev via make up-develop)
# Resend (local smoke against real inbox):
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# EMAIL_TIMEOUT=30
# SERVER_EMAIL=noreply@palingames.by
# DEFAULT_FROM_EMAIL=noreply@palingames.by
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# --- Database (local Postgres; see docker-compose.develop.yml) ---
POSTGRES_USER=palingames_user
POSTGRES_PASSWORD=palingames_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=palingames_dev
DATABASE_URL=postgres://palingames_user:palingames_pass@localhost:5433/palingames_dev

# --- Redis / Celery / cache ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CACHE_REDIS_URL=redis://localhost:6379/1
RATE_LIMIT_REDIS_URL=redis://localhost:6379/2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=False
# CELERY_TASK_TIME_LIMIT=300
# CELERY_TASK_EAGER_PROPAGATES=True

# --- Local observability (docker-compose.develop.yml host ports) ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# --- Payments: Express Pay ---
EXPRESS_PAY_TOKEN=test-token
EXPRESS_PAY_REQUEST_SECRET_WORD=secret
EXPRESS_PAY_WEBHOOK_SECRET_WORD=secret
EXPRESS_PAY_USE_SIGNATURE=True
EXPRESS_PAY_IS_TEST=True
EXPRESS_PAY_INVOICE_LIFETIME_HOURS=24
# Dev shortcuts (optional):
# EXPRESS_PAY_USE_SIGNATURE=False
# EXPRESS_PAY_INVOICE_LIFETIME_HOURS=1
PAYMENTS_STATUS_SYNC_BATCH_SIZE=50
PAYMENTS_STATUS_SYNC_MIN_INTERVAL_SECONDS=300

# --- S3 / object storage ---
# Local MinIO (make up-develop):
S3_PRODUCT_IMAGES_ENABLED=true
S3_PRODUCT_IMAGES_PREFIX=previews
S3_PRODUCT_IMAGES_PUBLIC_BASE_URL=

S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_REGION_NAME=us-east-1
S3_BUCKET_NAME=products
# Contabo (staging/prod-like local test):
# S3_ENDPOINT_URL=https://eu2.contabostorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION_NAME=
# S3_BUCKET_NAME=palingames.products
S3_ADDRESSING_STYLE=path
S3_USE_SSL=False
S3_CONNECT_TIMEOUT_SECONDS=5
S3_READ_TIMEOUT_SECONDS=30
S3_MAX_POOL_CONNECTIONS=10
S3_RETRY_MAX_ATTEMPTS=3
S3_PRESIGNED_EXPIRE_SECONDS=120

# S3 admin files upload
ADMIN_DIRECT_S3_UPLOAD_ENABLED=false
ADMIN_DIRECT_S3_UPLOAD_MAX_BYTES=524288000
ADMIN_DIRECT_S3_UPLOAD_PRESIGN_TTL_SECONDS=900
ADMIN_DIRECT_S3_UPLOAD_ALLOWED_EXTENSIONS=.zip,.pdf,.rar,.7z

# --- Public site URLs ---
SITE_BASE_URL=http://127.0.0.1:8000

# --- Marketing analytics ---
# Turn on only when GTM / GA4 are configured.
ANALYTICS_ENABLED=False
GTM_ID=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
YANDEX_METRIKA_ID=
META_PIXEL_ID=
CLARITY_PROJECT_ID=
# Cookie consent (optional; defaults: POLICY_VERSION=1, MAX_AGE=180 days)
COOKIE_CONSENT_POLICY_VERSION=1
COOKIE_CONSENT_MAX_AGE_SECONDS=15552000
PERSONAL_DATA_POLICY_VERSION=1

# --- Email / admin recipients ---
CUSTOM_GAME_ADMIN_EMAILS=admin@example.com
REVIEW_ADMIN_EMAILS=admin@example.com

# --- Reward promos ---
REVIEW_REWARD_DISCOUNT_PERCENT=10
REVIEW_REWARD_VALID_DAYS=14
ORDER_REWARD_DISCOUNT_PERCENT=10
ORDER_REWARD_VALID_DAYS=14
# Example override used in local dev:
# ORDER_REWARD_DISCOUNT_PERCENT=15
ORDER_REWARD_MIN_TOTAL_AMOUNT=25

# --- Guest access / download links ---
GUEST_ACCESS_EXPIRE_HOURS=24
GUEST_ACCESS_MAX_DOWNLOADS=3
GUEST_ACCESS_EMAIL_OUTBOX_SENT_RETENTION_DAYS=30
GUEST_ACCESS_EMAIL_OUTBOX_FAILED_RETENTION_DAYS=90

# --- App-level secrets / error reporting ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_DATA_ENCRYPTION_KEY=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Checkout rate limits ---
CHECKOUT_CREATE_EMAIL_RATE_LIMIT=5
CHECKOUT_CREATE_EMAIL_RATE_LIMIT_WINDOW_SECONDS=600
CHECKOUT_CREATE_IP_RATE_LIMIT=20
CHECKOUT_CREATE_IP_RATE_LIMIT_WINDOW_SECONDS=3600

CHECKOUT_PROMO_APPLY_EMAIL_RATE_LIMIT=20
CHECKOUT_PROMO_APPLY_EMAIL_RATE_LIMIT_WINDOW_SECONDS=600
CHECKOUT_PROMO_APPLY_IP_RATE_LIMIT=30
CHECKOUT_PROMO_APPLY_IP_RATE_LIMIT_WINDOW_SECONDS=600

# --- Auth rate limits: login ---
AUTH_LOGIN_EMAIL_RATE_LIMIT=5
AUTH_LOGIN_EMAIL_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_LOGIN_IP_RATE_LIMIT=30
AUTH_LOGIN_IP_RATE_LIMIT_WINDOW_SECONDS=600

# --- Auth rate limits: signup ---
AUTH_SIGNUP_EMAIL_RATE_LIMIT=3
AUTH_SIGNUP_EMAIL_RATE_LIMIT_WINDOW_SECONDS=3600
AUTH_SIGNUP_IP_RATE_LIMIT=10
AUTH_SIGNUP_IP_RATE_LIMIT_WINDOW_SECONDS=3600

# --- Auth rate limits: password reset request ---
AUTH_PASSWORD_RESET_REQUEST_EMAIL_RATE_LIMIT=3
AUTH_PASSWORD_RESET_REQUEST_EMAIL_RATE_LIMIT_WINDOW_SECONDS=3600
AUTH_PASSWORD_RESET_REQUEST_IP_RATE_LIMIT=10
AUTH_PASSWORD_RESET_REQUEST_IP_RATE_LIMIT_WINDOW_SECONDS=3600

# --- Auth rate limits: password reset confirm ---
AUTH_PASSWORD_RESET_CONFIRM_KEY_RATE_LIMIT=5
AUTH_PASSWORD_RESET_CONFIRM_KEY_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_PASSWORD_RESET_CONFIRM_IP_RATE_LIMIT=20
AUTH_PASSWORD_RESET_CONFIRM_IP_RATE_LIMIT_WINDOW_SECONDS=600

# --- Auth rate limits: password change ---
ACCOUNT_PASSWORD_CHANGE_USER_RATE_LIMIT=5
ACCOUNT_PASSWORD_CHANGE_USER_RATE_LIMIT_WINDOW_SECONDS=600
ACCOUNT_PASSWORD_CHANGE_IP_RATE_LIMIT=20
ACCOUNT_PASSWORD_CHANGE_IP_RATE_LIMIT_WINDOW_SECONDS=600

# --- Downloads rate limits ---
PRODUCT_DOWNLOAD_USER_RATE_LIMIT=20
PRODUCT_DOWNLOAD_USER_RATE_LIMIT_WINDOW_SECONDS=300
PRODUCT_DOWNLOAD_PRODUCT_RATE_LIMIT=3
PRODUCT_DOWNLOAD_PRODUCT_RATE_LIMIT_WINDOW_SECONDS=60

# --- OAuth providers ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=

# --- Telegram (ignored during manage.py test — see config/settings_test.py) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_FORUM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_THREAD_ID=
TELEGRAM_SUPPORT_THREAD_ID=
TELEGRAM_INCIDENTS_THREAD_ID=

# --- Incidents (Telegram alerts) ---
INCIDENT_ALERT_DEDUPE_TTL_SECONDS=900
PAYMENT_WEBHOOK_INCIDENT_THRESHOLD=5
PAYMENT_WEBHOOK_INCIDENT_WINDOW_SECONDS=600
PAYMENT_STATUS_SYNC_INCIDENT_THRESHOLD=5
PAYMENT_STATUS_SYNC_INCIDENT_WINDOW_SECONDS=900
DOWNLOAD_DELIVERY_INCIDENT_THRESHOLD=3
DOWNLOAD_DELIVERY_INCIDENT_WINDOW_SECONDS=900
NOTIFICATION_OUTBOX_INCIDENT_THRESHOLD=3
NOTIFICATION_OUTBOX_INCIDENT_WINDOW_SECONDS=900
STORAGE_INCIDENT_THRESHOLD=3
STORAGE_INCIDENT_WINDOW_SECONDS=900
