# Copy to deploy/.env and fill in secrets. Paths are for docker-compose.prod.yml from deploy/.

# --- Public URL & Django ---
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
# Comma-separated origins, e.g. https://your-domain.com,https://www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DJANGO_USE_WHITENOISE=true
TAILWIND_CLI_USE_MINIFY=true
DJANGO_LOG_LEVEL=INFO
SITE_BASE_URL=https://your-domain.com

# Caddy site label (see deploy/Caddyfile). Use bare hostname for automatic HTTPS, or http://localhost for plain HTTP.
CADDY_DOMAIN=your-domain.com

# Docker image (must match deploy_remote.sh / CI). When building locally, compose defaults apply.
# PALINGAMES_WEB_REF=yourdockerhub/palingames:latest

# --- Database (host = postgres service name) ---
POSTGRES_DB=palingames
POSTGRES_USER=palingames
POSTGRES_PASSWORD=
DATABASE_URL=postgres://palingames:CHANGE_ME@postgres:5432/palingames

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CACHE_REDIS_URL=redis://redis:6379/1
RATE_LIMIT_REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# --- Required secrets (see repository .env.example for full list) ---
APP_DATA_ENCRYPTION_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=

# --- Email (production SMTP) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# --- Payments, S3, Telegram, Sentry (production values) ---
# EXPRESS_PAY_*, S3_*, TELEGRAM_*, SENTRY_DSN, etc.

# --- Optional ---
SENTRY_RELEASE=
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
